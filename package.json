{
  "name": "md-reader",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install",
    "link-core": "bash scripts/link-core.sh",
    "install:remote": "npm run install:all && npm run link-core"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.1.1"
  }
}
